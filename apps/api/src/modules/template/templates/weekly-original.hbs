<html lang='hu'>

<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  <title>Heti Ajánlat</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 20px;
      background-color: #f5f5f5;
    }

    .menu-container {
      background-color: white;
      padding: 20px;
      max-width: 800px;
      margin: 0 auto;
      min-height: calc(100vh - 40px);
    }

    .header {
      text-align: center;
      margin-bottom: 20px;
    }

    .restaurant-name {
      font-size: 18px;
      font-weight: bold;
      text-decoration: underline;
      margin-bottom: 5px;
    }

    .restaurant-info {
      font-size: 12px;
      margin-bottom: 20px;
    }

    .week-title {
      font-size: 16px;
      font-weight: bold;
      letter-spacing: 2px;
      margin-bottom: 10px;
    }

    .week-dates {
      font-size: 14px;
      margin-bottom: 15px;
    }

    .fixed-items {
      margin-bottom: 20px;
    }

    .fixed-items table {
      width: 100%;
      border-collapse: collapse;
    }

    .fixed-items td {
      padding: 2px 0;
      font-size: 14px;
    }

    .fixed-items .item-name {
      width: 10%;
    }

    .fixed-items .item-price {
      width: 30%;
    }

    /* --- Main Menu Table --- */
    .menu-table {
      width: 100%;
      border-collapse: collapse;
      border: 3px solid black;
    }

    /* Direct child cells of the main table */
    .menu-table>tbody>tr>td {
      border: 1px solid black;
      vertical-align: middle;
      font-size: 12px;
    }

    .day-cell {
      font-weight: bold;
      width: 12%;
      padding: 6px;
      background-color: #f0f0f0;
      border-left: 2px solid black;
      border-right: 2px solid black;
    }

    .food-cell {
      width: 88%;
      border-right: 2px solid black;
      /* Padding is 0 to allow the nested table to fill the space */
      padding: 0;
    }

    .menu-label {
      font-weight: bold;
      display: inline-block;
      padding: 2px 4px;
      margin-bottom: 2px;
    }

    .empty-day {
      color: #666;
      font-style: italic;
      padding-left: 6px;
      /* Re-adds padding that was on the parent cell */
    }

    /* --- Nested Dish Table (inside .food-cell) --- */
    .dish-table {
      width: 100%;
      border-collapse: collapse;
    }

    .dish-table td {
      padding: 2px 6px;
      vertical-align: top;
      border: none;
      border: 1px solid black;
    }

    /* Remove outer borders */
    .dish-table tr:first-child td {
      border-top: none;
    }

    .dish-table tr:last-child td {
      border-bottom: none;
    }

    .dish-table tr td:first-child {
      border-left: none;
    }

    .dish-table tr td:last-child {
      border-right: none;
    }


    .dish-name-cell {
      width: 88%;
    }

    .dish-price-cell {
      width: 12%;
      text-align: center;
      font-weight: bold;
      border-left: 1px solid black;
      background-color: #fafafa;
    }

    .dish-row {}

    /* Adds a separator line BETWEEN items, but not after the last one */
    .dish-row:not(:last-child)>td {
      border-bottom: 1px solid #ddd;
    }

    .footer {
      margin-top: 20px;
      font-size: 12px;
      text-align: center;
    }

    .footer p {
      margin: 5px 0;
    }

    .watermark {
      position: fixed;
      bottom: 20px;
      right: 20px;
      font-size: 12px;
      font-style: italic;
      color: rgba(0, 0, 0, 0.4);
      pointer-events: none;
    }

    /* --- Print Styles --- */
    @media print {
      body {
        margin: 0;
        background-color: white;
      }

      .menu-container {
        padding: 15px;
        min-height: auto;
        box-shadow: none;
      }

      .watermark {
        position: absolute;
        bottom: 10px;
        right: 15px;
      }

      .footer {
        margin-bottom: 30px;
      }
    }
  </style>
</head>

<body>
  <div class='menu-container'>
    <div class='header'>
      <div class='restaurant-name'>ZÓNA ÉTTEREM</div>
      <div class='restaurant-name'>VESZPRÉM</div>
      <div class='restaurant-info'>
        RADNÓTI TÉR 2<br />
        TEL.: 88/426-706
      </div>

      <div class='week-title'>H E T I &nbsp; A J Á N L A T</div>
      <div class='week-dates'>{{formatDateRange weekStart weekEnd}}</div>
    </div>

    <div class='fixed-items'>
      <table>
        <tr>
          <td class='item-name'><strong>Levesek:</strong></td>
          <td class='item-price'><strong>900.-</strong></td>
        </tr>
        <tr>
          <td class='item-name'><strong>Húsos levesek:</strong></td>
          <td class='item-price'><strong>1000.-</strong></td>
        </tr>
        <tr>
          <td class='item-name'><strong>Saláták:</strong></td>
          <td class='item-price'><strong>800.-</strong></td>
        </tr>
        <tr>
          <td class='item-name'><strong>Köretek:</strong></td>
          <td class='item-price'><strong>800.-</strong></td>
        </tr>
      </table>
    </div>

    <table class='menu-table'>
      <tbody>
        {{#each (getDaysInOrder days weekStart)}}
        <tr>
          <td class='day-cell'>{{this.dayName}}</td>
          <td class='food-cell'>
            <table class='dish-table'>
              <tbody>
                {{#if (or this.dayData.offers this.dayData.menus)}}
                {{! Loop through daily offers if they exist }}
                {{#each this.dayData.offers}}
                <tr class="dish-row">
                  <td class='dish-name-cell'>{{this.dish.dishName}}</td>
                  <td class='dish-price-cell'>{{#if this.price}}{{formatPrice this.price}}{{/if}}</td>
                </tr>
                {{/each}}

                {{! Loop through menus if they exist }}
                {{#each this.dayData.menus}}
                <tr class="dish-row">
                  <td class='dish-name-cell'>
                    <div class='menu-label'>{{this.menuName}}</div>
                    {{#each this.dishes}}{{this.dishName}}{{#unless @last}}, {{/unless}}{{/each}}
                  </td>
                  <td class='dish-price-cell'>{{formatPrice this.price}}</td>
                </tr>
                {{/each}}
                {{else}}
                {{! This displays if a day has no offers and no menus }}
                <tr class="dish-row">
                  <td class='dish-name-cell empty-day'>-</td>
                  <td class="dish-price-cell"></td>
                </tr>
                {{/if}}
              </tbody>
            </table>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class='footer'>
      <p><strong>Elviteles doboz ára: 100 FT</strong></p>
      <p>Étlapunk aktuális ajánlata a Facebook oldalon tekinthető meg.</p>
      <p><em>Jó étvágyat kíván az egész Zóna étterem személyzete!</em></p>
    </div>
  </div>

  <div class='watermark'>Készítette a menuportal.hu</div>
</body>

</html>