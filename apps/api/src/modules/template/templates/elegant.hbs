<html lang='hu'>

<head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Heti Ajánlat - Elegáns</title>
    <style>
        body {
            font-family: 'Georgia', serif;
            /* Further reduced margins for better A4 fit */
            margin: 5px;
            background: linear-gradient(135deg, #f8f6f0 0%, #f0ede5 100%);
            position: relative;
            color: #3a3a3a;
        }

        .menu-container {
            position: relative;
            background-color: #ffffff;
            /* Further reduced padding from 20px to 12px for A4 fit */
            padding: 12px;
            max-width: 800px;
            margin: 0 auto;
            border-radius: 8px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            /* Removed container border that was causing the unwanted border line */
        }

        .header {
            text-align: center;
            /* Further reduced margin from 20px to 8px */
            margin-bottom: 8px;
            position: relative;
        }

        .header::after {
            content: '';
            position: absolute;
            /* Reduced bottom position from -10px to -6px */
            bottom: -6px;
            left: 50%;
            transform: translateX(-50%);
            width: 120px;
            height: 2px;
            background: linear-gradient(90deg, transparent, #d4af37, transparent);
        }

        .restaurant-name {
            /* Increased font size from 18px to 22px for better readability */
            font-size: 22px;
            font-weight: 300;
            color: #2c2c2c;
            /* Reduced margin from 6px to 4px */
            margin-bottom: 4px;
            letter-spacing: 2px;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.1);
        }

        .restaurant-info {
            /* Increased font size from 10px to 12px */
            font-size: 12px;
            /* Reduced margin from 12px to 8px */
            margin-bottom: 8px;
            color: #666;
            font-style: italic;
            line-height: 1.6;
        }

        .week-title {
            /* Increased font size from 15px to 18px */
            font-size: 18px;
            font-weight: 400;
            letter-spacing: 4px;
            /* Reduced margin from 10px to 6px */
            margin-bottom: 6px;
            color: #d4af37;
            text-transform: uppercase;
        }

        .week-dates {
            /* Increased font size from 12px to 14px */
            font-size: 14px;
            /* Reduced margin from 12px to 8px */
            margin-bottom: 8px;
            font-weight: 500;
            color: #555;
        }

        .fixed-items {
            /* Increased margin from 10px to 15px */
            margin-bottom: 10px;
            background: linear-gradient(135deg, #faf9f7 0%, #f5f3ef 100%);
            /* Increased padding from 8px to 12px */
            padding: 8px;
            border-radius: 6px;
            border: 1px solid #e8e0d0;
        }

        .fixed-items table {
            width: 100%;
            border-collapse: collapse;
        }

        .fixed-items td {
            /* Increased padding from 3px to 5px */
            padding: 5px 0;
            /* Increased font size from 11px to 13px */
            font-size: 13px;
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
        }

        .fixed-items .item-name {
            width: 40%;
            font-weight: 600;
            color: #444;
        }

        .fixed-items .item-price {
            width: 60%;
            text-align: right;
            font-weight: 700;
            color: #d4af37;
        }

        .menu-table {
            width: 100%;
            border-collapse: collapse;
            border-radius: 6px;
            overflow: hidden;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
        }

        .menu-table th,
        .menu-table td {
            border: 1px solid #e8e0d0;
            /* Reduced padding from 10px to 8px */
            padding: 8px;
            text-align: left;
            vertical-align: top;
            /* Increased font size from 10px to 12px */
            font-size: 12px;
        }

        .day-cell {
            font-weight: 600;
            width: 15%;
            background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
            color: white;
            text-align: center;
            /* Increased font size from 9px to 11px */
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
        }

        .food-cell {
            width: 65%;
            /* Reduced padding from 10px 12px to 8px 10px */
            padding: 8px 10px;
            line-height: 1.5;
            background-color: #fefefe;
        }

        .price-cell {
            width: 20%;
            text-align: center;
            font-weight: 600;
            background: linear-gradient(135deg, #faf9f7 0%, #f5f3ef 100%);
            color: #d4af37;
        }

        .menu-label {
            font-weight: 600;
            display: inline-block;
            /* Increased padding from 2px 6px to 3px 8px */
            padding: 3px 8px;
            /* Increased margin from 2px to 3px */
            margin-bottom: 3px;
            background: linear-gradient(135deg, #2c2c2c 0%, #444 100%);
            color: white;
            /* Increased font size from 8px to 10px */
            font-size: 10px;
            text-transform: uppercase;
            border-radius: 3px;
            letter-spacing: 0.5px;
        }

        .dish-item {
            /* Increased margin from 2px to 3px */
            margin: 3px 0;
            /* Increased padding from 1px to 2px */
            padding: 2px 0;
            border-bottom: 1px solid rgba(212, 175, 55, 0.1);
            transition: all 0.2s ease;
        }

        .dish-item:last-child {
            border-bottom: none;
        }

        .dish-item:hover {
            color: #d4af37;
        }

        .empty-day {
            color: #bbb;
            font-style: italic;
            text-align: center;
            font-size: 16px;
        }

        .footer {
            /* Increased margin from 12px to 18px */
            margin-top: 12px;
            /* Increased font size from 9px to 11px */
            font-size: 11px;
            text-align: center;
            /* Reduced margin from 25px to 15px */
            margin-bottom: 15px;
            /* Reduced padding from 12px to 8px */
            padding-top: 8px;
            position: relative;
            color: #666;
        }

        .footer::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 120px;
            height: 1px;
            background: linear-gradient(90deg, transparent, #d4af37, transparent);
        }

        .footer p {
            /* Increased margin from 3px to 5px */
            margin: 5px 0;
            line-height: 1.5;
        }

        .footer strong {
            color: #d4af37;
        }

        .watermark {
            position: fixed;
            bottom: 20px;
            right: 20px;
            font-size: 12px;
            font-style: italic;
            color: rgba(0, 0, 0, 0.4);
            pointer-events: none;
            user-select: none;
            z-index: 1000;
            background-color: rgba(255, 255, 255, 0.9);
            padding: 4px 8px;
            border-radius: 4px;
            border: 1px solid rgba(212, 175, 55, 0.2);
        }

        /* Print-specific styles */
        @media print {
            body {
                margin: 0;
                background: white;
            }

            .menu-container {
                /* Further reduced print padding from 12px to 5px and removed border */
                padding: 5px;
                min-height: auto;
                box-shadow: none;
            }

            .header::after {
                content: '';
                position: absolute;
                bottom: -10px;
                left: 50%;
                transform: translateX(-50%);
                width: 120px;
                height: 2px;
                background: linear-gradient(90deg, transparent, #d4af37, transparent);
            }

            .day-cell {
                background: #d4af37 !important;
                -webkit-print-color-adjust: exact;
                color-adjust: exact;
            }

            .footer {
                /* Further reduced print margin from 10px to 5px */
                margin-bottom: 5px;
            }
        }
    </style>
</head>

<body>
    <div class='menu-container'>
        <div class='header'>
            <div class='restaurant-name'>ZÓNA ÉTTEREM</div>
            <div class='restaurant-name'>VESZPRÉM</div>
            <div class='restaurant-info'>
                RADNÓTI TÉR 2<br />
                TEL.: 88/426-706
            </div>

            <div class='week-title'>H E T I &nbsp; A J Á N L A T</div>
            <div class='week-dates'>{{formatDateRange weekStart weekEnd}}</div>
        </div>

        <div class='fixed-items'>
            <table>
                <tr>
                    <td class='item-name'>Levesek:</td>
                    <td class='item-price'>900.-</td>
                </tr>
                <tr>
                    <td class='item-name'>Húsos levesek:</td>
                    <td class='item-price'>1000.-</td>
                </tr>
                <tr>
                    <td class='item-name'>Saláták:</td>
                    <td class='item-price'>800.-</td>
                </tr>
                <tr>
                    <td class='item-name'>Köretek:</td>
                    <td class='item-price'>800.-</td>
                </tr>
            </table>
        </div>

        <table class='menu-table'>
            {{#each (getDaysInOrder days weekStart)}}
            <tr>
                <td class='day-cell'>{{this.dayName}}</td>
                <td class='food-cell'>
                    {{#if this.dayData.offers}}
                    {{#each this.dayData.offers}}
                    <div class='dish-item'>{{this.dish.dishName}}</div>
                    {{/each}}
                    {{/if}}

                    {{#if this.dayData.menus}}
                    {{#each this.dayData.menus}}
                    <div class='dish-item'>
                        <div class='menu-label'>{{this.menuName}}</div>
                        {{#each this.dishes}}
                        {{this.dishName}}{{#unless @last}}, {{/unless}}
                        {{/each}}
                    </div>
                    {{/each}}
                    {{/if}}

                    {{#unless (or this.dayData.offers this.dayData.menus)}}
                    <span class='empty-day'>-</span>
                    {{/unless}}
                </td>
                <td class='price-cell'>
                    {{#if this.dayData.offers}}
                    {{#each this.dayData.offers}}
                    <div class='dish-item'>
                        {{#if this.price}}{{formatPrice this.price}}{{/if}}
                    </div>
                    {{/each}}
                    {{/if}}

                    {{#if this.dayData.menus}}
                    {{#each this.dayData.menus}}
                    <div class='dish-item'>{{formatPrice this.price}}</div>
                    {{/each}}
                    {{/if}}

                    {{#unless (or this.dayData.offers this.dayData.menus)}}
                    <span class='empty-day'>-</span>
                    {{/unless}}
                </td>
            </tr>
            {{/each}}
        </table>

        <div class='footer'>
            <p><strong>Elviteles doboz ára: 100 FT</strong></p>
            <p>Étlapunk aktuális ajánlata a Facebook oldalon tekinthető meg.</p>
            <p><em>Jó étvágyat kíván az egész Zóna étterem személyzete!</em></p>
        </div>
    </div>

    <div class='watermark'>Készítette a menuportal.hu</div>
</body>

</html>