{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"]
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "api:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "api:build:development"
        },
        "production": {
          "buildTarget": "api:build:production"
        }
      }
    },
    "database:migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm drizzle-kit migrate --config=apps/api/drizzle.config.ts",
        "cwd": "apps/api"
      }
    },
    "database:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm drizzle-kit generate --config=apps/api/drizzle.config.ts",
        "cwd": "apps/api"
      }
    },
    "database:push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm drizzle-kit push --config=apps/api/drizzle.config.ts",
        "cwd": "apps/api"
      }
    },
    "database:seed": {},
    "generate-client": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm dlx orval && pnpm exec nx run clients:lint",
        "cwd": "apps/api"
      },
      "outputs": ["{projectRoot}/libs/api-client"]
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/api/Dockerfile -t api:latest ."
      }
    },
    "docker-run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker run --env-file ./.env --network=mono-repo_services-network -p 3000:3000 api:latest"
      }
    },
    "deploy": {
      "command": "fly deploy -c apps/api/fly.toml --dockerfile apps/api/Dockerfile"
    }
  }
}
